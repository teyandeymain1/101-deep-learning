{
  "name": "python",
  "build": {
    "dockerfile": "./Dockerfile",
    "context": "."
  },
  "workspaceMount": "source=c:/Users/teyan/Desktop/programming/01-python-codes,target=/home/python_with_docker,type=bind,consistency=cached", // for PCUnit1
  //"workspaceMount": "source=/home/yuta/programming/sunagawa_private/01-python-codes,target=/home/python_with_docker,type=bind,consistency=cached", // for lab pc
  "workspaceFolder": "/home/python_with_docker",
  "customizations": {
    "vscode": {
      "settings": {
        "files.autoSave": "afterDelay",
        "files.autoSaveDelay": 1000,
        "editor.tabSize": 2
      },
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "oderwat.indent-rainbow",
        "streetsidesoftware.code-spell-checker"
      ]
    }
  },
  "shutdownAction": "stopContainer"
}